# Copy this to .env and fill in your values
# ------------------------------------------------

# Django (legacy — safe to ignore for the FastAPI app)
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=false

# ─── API Keys (required for pipeline to run) ──────────────────────────
GEMINI_API_KEY=your-gemini-key-here
OPENAI_API_KEY=your-openai-key-here
PEXELS_API_KEY=your-pexels-key-here

# ─── Express Mode keys (optional — server-side defaults) ──────────────
# Express Mode keys live in browser localStorage per-user. These env
# vars are server-side fallbacks ONLY (used if you wire it up later).
# Anthropic Claude (Sonnet 4.6) — SEO/trim/shorts planner.
# ANTHROPIC_API_KEY=sk-ant-...
# Groq Whisper Large v3 — best Indic-language transcription accuracy.
# GROQ_API_KEY=gsk_...
# Optional: override the rsvg-convert binary path if it's not on PATH.
# Falls back to Pillow when rsvg-convert is missing.
# KAIZER_RSVG_PATH=C:\path\to\rsvg-convert.exe

# ─── HeyGen avatar generation (Trending → 1-click avatar video) ──────
# Sign up at https://app.heygen.com, then Account → Settings →
# API Subscription → Create new API key. Free tier has 10 min/month
# generation budget; Creator tier ($24/mo) is the realistic floor.
HEYGEN_API_KEY=
# Optional fallback default avatar / voice — overridden by per-user
# preferences (stored on the users table) when present.
HEYGEN_DEFAULT_AVATAR_ID=
HEYGEN_DEFAULT_VOICE_ID=

# Output directory (optional — defaults to backend/output/)
# On Railway, set this to a mounted volume path e.g. /data/output
# KAIZER_OUTPUT_ROOT=/data/output

# ─── YouTube OAuth (Phase 4+: Connect a channel, upload, scheduling) ──
# Create at: https://console.cloud.google.com/apis/credentials
#   1. Create an OAuth 2.0 Client ID of type "Web application"
#   2. Add authorized redirect URI: http://localhost:8000/api/youtube/oauth/callback
#   3. Enable "YouTube Data API v3" on the same project
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/youtube/oauth/callback

# Separate public API key (no OAuth) used for channel-learning / competitor queries
YOUTUBE_DATA_API_KEY=

# ─── Encryption (auto-generated on first startup — do not share) ──────
# Used to encrypt stored OAuth refresh_tokens. If you regenerate this
# key, all connected channels must reconnect.
KAIZER_ENCRYPTION_KEY=

# ─── Postiz cross-post (admin-only feature) ───────────────────────────
# Optional. Self-host with `docker compose -f docker-compose.postiz.yml up -d`
# then open http://localhost:5000 → Settings → API Keys to generate a
# token. Leave both empty to hide the cross-post UI for everyone.
POSTIZ_BASE_URL=http://localhost:5000
POSTIZ_API_KEY=
