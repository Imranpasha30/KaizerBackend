# Django
*.pyc
__pycache__/
db.sqlite3
media/
staticfiles/
*.log

# Environment — match every flavour: .env, .env.local, .env.production,
# .env.staging, .env.foo.bak etc. Only .env.example (the public template)
# is tracked.
.env
.env.*
!.env.example

# Output (generated clips — large files, gitignore)
output/

# Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp

# Work-monitor live event log (per-machine state, never code)
logs/
