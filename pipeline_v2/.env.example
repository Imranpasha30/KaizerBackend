# Pipeline V2 environment variables.
# Copy to .env (NEVER commit .env) and fill in real values.
# The v1 pipeline reads its own env separately; v2 reuses GEMINI_API_KEY
# only — every other key is v2-specific.

# --- Stage 1 (multi-provider STT) ---
# Step 4 expanded Stage 1 into a provider-abstraction layer with five
# backends (Chirp 3 / Whisper-Groq / Deepgram / AssemblyAI / Sarvam).
# Each provider has its own credentials below. The dispatcher picks
# the provider at call time; you only need creds for the providers
# you actually use.

# --- Chirp 3 (Google Cloud Speech-to-Text v2; Step 4.1) ---
# Service-account JSON file path. Service account needs the
# roles/speech.client role. The same SA also needs roles/storage.objectAdmin
# on the temp bucket below if you transcribe files >10MB.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=asia-south1
# Temp GCS bucket for files >10MB (Chirp 3 sync API limit). 24h
# lifecycle TTL recommended. Naming convention mirrors R2's
# local/prod prefix split:
#   dev:  KAIZER_GCS_STT_BUCKET=kaizer-stt-temp-local
#   prod: KAIZER_GCS_STT_BUCKET=kaizer-stt-temp-prod
KAIZER_GCS_STT_BUCKET=kaizer-stt-temp-local

# --- Whisper-Groq (api.groq.com, OpenAI-compatible; Step 4.2) ---
GROQ_API_KEY=
# Tier selector for cost-ledger accuracy:
#   free  -> per-file cap 25 MB, 480 audio-min/day, $0/hr     (default)
#   dev   -> per-file cap 100 MB, higher quota,      $0.04/hr
# Promotion to dev tier is the Step 12->13 decision; the provider code
# is identical against both.
GROQ_TIER=free
# Optional: override the Groq model (default whisper-large-v3).
# Set to whisper-large-v3-turbo for ~2x speed at a quality tradeoff.
GROQ_MODEL=

# --- Deepgram Nova-3 (Step 4.3) ---
DEEPGRAM_API_KEY=

# --- AssemblyAI Universal-2 (Step 4.4) ---
ASSEMBLYAI_API_KEY=

# --- Sarvam AI (Step 4.5, gated on word-level timestamp support) ---
SARVAM_API_KEY=

# --- Stage 2 / 2.5 / 3a / 3b / 3c (Gemini 2.5 Pro + Flash) ---
# Same key the v1 pipeline already uses. Don't re-paste in chat;
# rotate if leaked.
GEMINI_API_KEY=

# --- Step 10 (Inngest durable execution) ---
# Dev mode: INNGEST_DEV=1, the rest can stay empty for local.
# Prod: set INNGEST_EVENT_KEY + INNGEST_SIGNING_KEY from the Inngest dashboard.
INNGEST_DEV=1
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_APP_ID=kaizer-news-v2

# --- Image generation (shared with v1) ---
# Existing pipeline.py uses these — same keys, same behaviour.
KAIZER_IMAGEN=                # backend selector: "gpt-image" | "imagen"
KAIZER_IMAGEN_MODEL=          # model id, e.g. "imagen-3.0-generate-002"
OPENAI_API_KEY=

# --- R2 storage (shared bucket with v1; v2 uses jobs/{id}/v2/ prefix) ---
# Existing pipeline already reads these. Listed here for completeness.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
